#!/usr/bin/env bash

# Active live-deployment preset.
# The rollout settings below stay fixed while `TROSSEN_POLICY_CKPT`
# points at the checkpoint currently under test.

: "${VLA_JEPA_REPO_ROOT:=/home/mehul/work/vjepa/VLA-JEPA}"
export VLA_JEPA_REPO_ROOT
: "${YONDU_TROSSEN_LEROBOT_ROOT:=/home/mehul/work/yondu-trossen-lerobot}"
export YONDU_TROSSEN_LEROBOT_ROOT
: "${VLA_JEPA_PYTHON:=/home/mehul/miniconda3/envs/vla-jepa-vjepa21/bin/python}"
export VLA_JEPA_PYTHON

: "${TROSSEN_POLICY_CKPT:=/home/mehul/work/vjepa/VLA-JEPA/checkpoints/robot_ft_trossen_vjepa21_small_5090_lerobot_20260408_203436/final_model}"
export TROSSEN_POLICY_CKPT

# Policy server bind address on the GPU machine.
: "${TROSSEN_POLICY_SERVER_HOST:=0.0.0.0}"
export TROSSEN_POLICY_SERVER_HOST
: "${TROSSEN_POLICY_SERVER_PORT:=10093}"
export TROSSEN_POLICY_SERVER_PORT

# Robot-side policy server target. If the robot runner is on a different machine,
# pass the GPU machine IP as the first arg to run_live_policy_weekend.sh.
: "${TROSSEN_POLICY_CLIENT_HOST:=127.0.0.1}"
export TROSSEN_POLICY_CLIENT_HOST

: "${TROSSEN_POLICY_CUDA:=0}"
export TROSSEN_POLICY_CUDA
: "${TROSSEN_POLICY_USE_BF16:=1}"
export TROSSEN_POLICY_USE_BF16

: "${TROSSEN_POLICY_INSTRUCTION:=Put the shirt in the other bin}"
export TROSSEN_POLICY_INSTRUCTION

# Training-matched rollout settings for this checkpoint.
# The raw dataset action column stores commanded joint goals, so rollout should
# execute the first predicted absolute goal each replan, with the same default
# Trossen relative-goal safety cap used during recording.
: "${TROSSEN_POLICY_ACTION_MODE:=absolute_qpos}"
export TROSSEN_POLICY_ACTION_MODE
: "${TROSSEN_POLICY_STATE_NORM_MODE:=min_max}"
export TROSSEN_POLICY_STATE_NORM_MODE
: "${TROSSEN_POLICY_ACTION_NORM_MODE:=min_max}"
export TROSSEN_POLICY_ACTION_NORM_MODE
: "${TROSSEN_POLICY_LIVE_FPS:=20}"
export TROSSEN_POLICY_LIVE_FPS
: "${TROSSEN_POLICY_LIVE_CHUNK_SIZE:=7}"
export TROSSEN_POLICY_LIVE_CHUNK_SIZE
: "${TROSSEN_POLICY_LIVE_NUM_STEPS:=120}"
export TROSSEN_POLICY_LIVE_NUM_STEPS
: "${TROSSEN_POLICY_LIVE_WARMUP_STEPS:=10}"
export TROSSEN_POLICY_LIVE_WARMUP_STEPS
: "${TROSSEN_POLICY_MAX_RELATIVE_TARGET:=5}"
export TROSSEN_POLICY_MAX_RELATIVE_TARGET
: "${TROSSEN_POLICY_LIVE_LOG_PATH:=/home/mehul/work/vjepa/checkpoints/trossen_rollout_logs/live_policy_weekend.jsonl}"
export TROSSEN_POLICY_LIVE_LOG_PATH
